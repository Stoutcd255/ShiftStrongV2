{
  "name": "shiftstrong",
  "version": "1.0.0",
  "description": "ShiftStrong tactical fitness and macro tracking app",
  "author": "Colten Stout",
  "license": "MIT",
  "main": "electron/main.js",
  "productName": "ShiftStrong",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"wait-on tcp:5173 && npm run electron\"",
    "build:web": "vite build",
    "dist": "npm run build:web && electron-builder",
    "dist:win": "npm run build:web && electron-builder --win nsis"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.9",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.shiftstrong.desktop",
    "productName": "ShiftStrong",
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShiftStrong",
      "artifactName": "ShiftStrong-Setup-${version}.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
